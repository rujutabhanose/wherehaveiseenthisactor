# Get your free API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=API_KEY

# ── Upstash Redis (server-side watchlist storage) ────────────────────────────
# In Vercel: Storage → Create Database → Marketplace → Upstash Redis
# After creating, "Connect" to this project — these vars will be injected automatically.
# For local dev: copy the values from the Upstash console (or Vercel project env tab).
# If these are not set, the app silently falls back to localStorage-only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
